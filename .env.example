# Sends every quote request to adamshaham04@gmail.com and to your Verizon phone
# (203-362-8259) as a text via 2033628259@vtext.com.
# Option A: keep the old Gmail setup (this is likely what made texts work before).
# GMAIL_APP_PASSWORD must be a Google App Password, not your normal Gmail password.
GMAIL_USER=adamshaham04@gmail.com
GMAIL_APP_PASSWORD=

# Option B: use another SMTP provider (Brevo, SendGrid, Mailgun, etc.).
# Easiest free option: Brevo → Settings → SMTP & API → create SMTP key, then:
#
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# Must be a sender you verified in Brevo (or your provider)
# SMTP_FROM="NAS Leads <you@yourdomain.com>"

# Defaults shown here. Only set these if you want to override them.
# NOTIFY_EMAIL=adamshaham04@gmail.com
# SMS_GATEWAY_EMAIL=2033628259@vtext.com
