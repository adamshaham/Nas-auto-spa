# Sends ONE email to your Verizon phone (203-362-8259) as a text via 2033628259@vtext.com — default, nothing to set.
# You still need an SMTP provider (e.g. Brevo) — not broken Gmail App Passwords.
# Easiest free option: Brevo → Settings → SMTP & API → create SMTP key, then:
#
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Must be a sender you verified in Brevo (or your provider)
SMTP_FROM="NAS Leads <you@yourdomain.com>"

# Optional: only if you change the notify number or carrier (e.g. AT&T: 2033628259@txt.att.net)
# SMS_GATEWAY_EMAIL=2033628259@vtext.com
